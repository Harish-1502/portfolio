---
const projects = [
  {
    title: "Gesture-Controlled Music Controller",
    description:
      "An embedded system for controlling media playback through hand gestures using sensor input and BLE communication.",
    bullets: [
      "Designed modular firmware for sensors, gesture detection, BLE communication, and state handling",
      "Improved structure by separating core system responsibilities into cleaner components",
      "Focused on calibration logic, validation, and reliability testing for more stable behavior",
    ],
    tech: "C++, ESP32, BLE, Embedded Firmware",
    github: "https://github.com/Harish-1502/Gesture-Controlled-Music-Controller",
  },
  {
    title: "Custom Wireless Macro Pad",
    description:
      "A programmable wireless macro pad built around the ESP32 for custom shortcuts and productivity workflows.",
    bullets: [
      "Built a custom embedded input device with wireless communication",
      "Structured the firmware for future expansion such as profiles and syncing",
      "Focused on usability, modularity, and hardware-software integration",
    ],
    tech: "ESP32, C++, BLE, Embedded Systems",
    github: "https://github.com/Harish-1502/Custom-Keyboard",
  },
  {
    title: "Smart Music Organizer",
    description:
      "A full-stack application for scanning, organizing, and managing a personal music library.",
    bullets: [
      "Built backend logic for recursive folder scanning, duplicate handling, and track indexing",
      "Connected frontend and backend into a cleaner product-style workflow",
      "Focused on solving a real user problem with practical features and structured architecture",
    ],
    tech: "FastAPI, React, Python, JavaScript, SQLite",
    github: "https://github.com/Harish-1502/smart-music-organizer",
  },
];

const skills = {
  Languages: ["C++", "C#", "Java", "JavaScript", "Python", "HTML", "CSS", "VHDL"],
  "Frameworks / Tools": ["FastAPI", "React", "WPF", "EF Core", "Git", "GitHub", "Docker", "SQLite"],
  Focus: ["Embedded Systems", "Firmware", "Desktop Applications", "Full-Stack Development", "Developer Tools"],
};
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Harish Thandayutham | Portfolio</title>
    <meta
      name="description"
      content="Computer Engineering student building embedded systems, software projects, and practical tools."
    />
    <style>
      :root {
        --bg: #080b14;
        --bg-2: #0d1222;
        --panel: rgba(18, 25, 45, 0.72);
        --panel-strong: rgba(21, 29, 52, 0.95);
        --text: #eef2ff;
        --muted: #a9b3ca;
        --muted-2: #8390ad;
        --accent: #7dd3fc;
        --accent-2: #8b5cf6;
        --line: rgba(255, 255, 255, 0.08);
        --line-strong: rgba(255, 255, 255, 0.14);
        --shadow: 0 10px 40px rgba(0, 0, 0, 0.28);
        --radius-xl: 28px;
        --radius-lg: 22px;
        --radius-md: 16px;
        --max-width: 1160px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
        color: var(--text);
        background:
          radial-gradient(circle at top left, rgba(125, 211, 252, 0.12), transparent 28%),
          radial-gradient(circle at top right, rgba(139, 92, 246, 0.12), transparent 26%),
          linear-gradient(180deg, var(--bg) 0%, var(--bg-2) 100%);
        line-height: 1.6;
      }

      a {
        text-decoration: none;
        color: inherit;
      }

      img {
        max-width: 100%;
        display: block;
      }

      .container {
        width: min(var(--max-width), calc(100% - 2rem));
        margin: 0 auto;
      }

      .site-shell {
        position: relative;
        overflow: hidden;
      }

      .site-shell::before,
      .site-shell::after {
        content: "";
        position: fixed;
        inset: auto;
        width: 420px;
        height: 420px;
        border-radius: 999px;
        filter: blur(90px);
        pointer-events: none;
        z-index: 0;
        opacity: 0.28;
      }

      .site-shell::before {
        top: -120px;
        left: -110px;
        background: rgba(125, 211, 252, 0.26);
      }

      .site-shell::after {
        top: 120px;
        right: -120px;
        background: rgba(139, 92, 246, 0.22);
      }

      .nav {
        position: sticky;
        top: 0;
        z-index: 50;
        backdrop-filter: blur(16px);
        background: rgba(8, 11, 20, 0.62);
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
      }

      .nav-inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 0;
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.1px;
      }

      .brand-dot {
        width: 12px;
        height: 12px;
        border-radius: 999px;
        background: linear-gradient(135deg, var(--accent), var(--accent-2));
        box-shadow: 0 0 22px rgba(125, 211, 252, 0.7);
      }

      .nav-links {
        display: flex;
        align-items: center;
        gap: 1.2rem;
        flex-wrap: wrap;
      }

      .nav-links a {
        color: var(--muted);
        font-size: 0.96rem;
        transition: color 0.2s ease;
      }

      .nav-links a:hover {
        color: var(--text);
      }

      .nav-cta {
        padding: 0.7rem 1rem;
        border-radius: 999px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.04);
        color: var(--text);
      }

      main,
      footer {
        position: relative;
        z-index: 1;
      }

      .hero {
        padding: 5.5rem 0 4rem;
      }

      .hero-grid {
        display: grid;
		grid-template-columns: minmax(0, 1.35fr) minmax(320px, 0.65fr);
		gap: 1.25rem;
		align-items: stretch;
      }

      .glass {
        background: var(--panel);
        border: 1px solid var(--line);
        box-shadow: var(--shadow);
        backdrop-filter: blur(14px);
      }

      .hero-main {
        border-radius: var(--radius-xl);
        padding: 2.1rem;
        position: relative;
        overflow: hidden;
      }

      .hero-main::before {
        content: "";
        position: absolute;
        inset: 0;
        background:
          linear-gradient(135deg, rgba(125, 211, 252, 0.08), transparent 35%),
          linear-gradient(315deg, rgba(139, 92, 246, 0.08), transparent 30%);
        pointer-events: none;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        padding: 0.45rem 0.8rem;
        border-radius: 999px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.04);
        color: var(--accent);
        font-size: 0.9rem;
        font-weight: 600;
      }

      .eyebrow::before {
        content: "";
        width: 8px;
        height: 8px;
        border-radius: 999px;
        background: var(--accent);
        box-shadow: 0 0 14px rgba(125, 211, 252, 0.75);
      }

      h1 {
        margin: 1.15rem 0 1rem;
        font-size: clamp(2.8rem, 6vw, 5.2rem);
        line-height: 0.98;
        letter-spacing: -0.05em;
        max-width: 12ch;
      }

      .hero-lead {
        max-width: 62ch;
        color: var(--muted);
        font-size: 1.05rem;
      }

      .hero-meta {
        margin-top: 1.5rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.7rem;
      }

      .meta-pill {
        padding: 0.55rem 0.85rem;
        border-radius: 999px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.03);
        color: var(--muted);
        font-size: 0.92rem;
      }

      .button-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.9rem;
        margin-top: 1.8rem;
      }

      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.55rem;
        min-height: 48px;
        padding: 0.9rem 1.1rem;
        border-radius: 14px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.04);
        color: var(--text);
        font-weight: 600;
        transition:
          transform 0.2s ease,
          border-color 0.2s ease,
          background 0.2s ease;
      }

      .btn:hover {
        transform: translateY(-2px);
        border-color: var(--line-strong);
      }

      .btn.primary {
        background: linear-gradient(135deg, var(--accent), #93c5fd 55%, #c4b5fd);
        color: #08111f;
        border-color: transparent;
      }

      .btn.primary:hover {
        background: linear-gradient(135deg, #8ae0ff, #a5ceff 55%, #d1c4ff);
      }

      .hero-side {
        display: flex;
      }

      .snapshot-card,
      .section-card,
      .project-card {
        border-radius: var(--radius-lg);
        padding: 1.3rem;
      }

      .snapshot-card h2,
      .status-card h3,
      .section-card h3,
      .project-card h3 {
        margin-top: 0;
      }

	  .snapshot-card {
		 width: 100%;
		 display: flex;
		 flex-direction: column;
		 justify-content: center;
		 min-height: 100%;
		}

      .snapshot-list,
      .status-list,
      .working-list,
      .project-card ul {
        margin: 0;
        padding-left: 1.1rem;
      }

      .snapshot-list li,
      .status-list li,
      .working-list li,
      .project-card li,
      .section-card p,
      .project-card p {
        color: var(--muted);
      }

      section {
        padding: 1.5rem 0 3.25rem;
      }

      .section-heading {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: end;
        margin-bottom: 1.4rem;
      }

      .section-title {
        margin: 0;
        font-size: clamp(1.85rem, 3vw, 2.5rem);
        letter-spacing: -0.03em;
      }

      .section-subtitle {
        margin: 0.35rem 0 0;
        color: var(--muted-2);
        max-width: 56ch;
      }

      .about-card {
        padding: 1.6rem;
        border-radius: var(--radius-xl);
      }

      .projects-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
      }

      .project-card {
        position: relative;
        overflow: hidden;
        transition:
          transform 0.22s ease,
          border-color 0.22s ease,
          background 0.22s ease,
          box-shadow 0.22s ease;
      }

      .project-card::before {
        content: "";
        position: absolute;
        inset: auto 0 0 0;
        height: 3px;
        background: linear-gradient(90deg, var(--accent), var(--accent-2));
        opacity: 0.75;
      }

      .project-card:hover {
        transform: translateY(-6px);
        border-color: rgba(125, 211, 252, 0.26);
        box-shadow: 0 18px 48px rgba(0, 0, 0, 0.34);
      }

      .project-top {
        display: flex;
        align-items: start;
        justify-content: space-between;
        gap: 0.8rem;
        margin-bottom: 0.7rem;
      }

      .project-index {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 34px;
        height: 34px;
        border-radius: 12px;
        background: rgba(125, 211, 252, 0.12);
        border: 1px solid rgba(125, 211, 252, 0.2);
        color: var(--accent);
        font-weight: 700;
        font-size: 0.92rem;
        flex-shrink: 0;
      }

      .tech {
        margin-top: 1rem;
        font-size: 0.94rem;
        color: var(--text);
      }

      .project-links {
        margin-top: 1rem;
      }

      .project-links a {
        color: var(--accent);
        font-weight: 700;
      }

      .project-links a:hover {
        color: #b4e7ff;
      }

      .skills-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
      }

      .tag-list {
        display: flex;
        flex-wrap: wrap;
        gap: 0.65rem;
        margin-top: 0.9rem;
      }

      .tag {
        padding: 0.5rem 0.78rem;
        border-radius: 999px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.035);
        color: var(--muted);
        font-size: 0.92rem;
      }

      .working-grid {
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        gap: 1rem;
      }

      .callout {
        padding: 1.3rem;
        border-radius: var(--radius-lg);
        border: 1px solid rgba(125, 211, 252, 0.16);
        background:
          linear-gradient(135deg, rgba(125, 211, 252, 0.09), transparent 60%),
          rgba(255, 255, 255, 0.035);
      }

      .callout p {
        margin: 0;
        color: var(--muted);
      }

      .contact-card {
        padding: 1.5rem;
        border-radius: var(--radius-xl);
      }

      .contact-top {
        display: flex;
        justify-content: space-between;
        gap: 1.2rem;
        align-items: start;
      }

      .contact-top p {
        max-width: 58ch;
        color: var(--muted);
      }

      .contact-links {
        display: flex;
        flex-wrap: wrap;
        gap: 0.85rem;
        margin-top: 1rem;
      }

      footer {
        padding: 1rem 0 3rem;
      }

      .footer-box {
        border-top: 1px solid var(--line);
        padding-top: 1.2rem;
        color: var(--muted-2);
        text-align: center;
      }

      @media (max-width: 980px) {
        .hero-grid,
        .projects-grid,
        .skills-grid,
        .working-grid {
          grid-template-columns: 1fr;
        }

        .contact-top,
        .section-heading,
        .nav-inner {
          flex-direction: column;
          align-items: flex-start;
        }

        h1 {
          max-width: 100%;
        }
      }

      @media (max-width: 720px) {
        .hero {
          padding-top: 4.2rem;
        }

        .hero-main,
        .snapshot-card,
        .section-card,
        .project-card,
        .contact-card,
        .about-card {
          padding: 1.15rem;
        }

        .status-grid {
          grid-template-columns: 1fr;
        }

        .nav-links {
          gap: 0.8rem;
        }
      }
    </style>
  </head>

  <body>
    <div class="site-shell">
      <nav class="nav">
        <div class="container nav-inner">
          <a href="#" class="brand">
            <span class="brand-dot"></span>
            <span>Harish Thandayutham</span>
          </a>

          <div class="nav-links">
            <a href="#about">About</a>
            <a href="#projects">Projects</a>
            <a href="#skills">Skills</a>
            <a href="#working-on">Working On</a>
            <a href="#contact" class="nav-cta">Contact</a>
          </div>
        </div>
      </nav>

      <main>
        <section class="hero container">
          <div class="hero-grid">
            <div class="hero-main glass">
              <div class="eyebrow">Computer Engineering Student</div>

              <h1>Embedded systems and software projects with real-world depth.</h1>

              <p class="hero-lead">
                I build practical systems across firmware, full-stack tools, and desktop software.
                My focus is on clean architecture, strong fundamentals, and projects that feel like
                real products instead of tutorials.
              </p>

              <div class="hero-meta">
                <span class="meta-pill">Embedded Systems</span>
                <span class="meta-pill">Firmware</span>
                <span class="meta-pill">Full-Stack Tools</span>
                <span class="meta-pill">Desktop Apps</span>
              </div>

              <div class="button-row">
                <a class="btn primary" href="#projects">View Projects</a>
                <a class="btn" href="https://github.com/Harish-1502" target="_blank" rel="noreferrer">GitHub</a>
                <a class="btn" href="https://www.linkedin.com/in/harish-thandayutham-4450282a9/" target="_blank" rel="noreferrer">LinkedIn</a>
                <a class="btn" href="/personal-website/src/pages/Thandayutham Resume.pdf" target="_blank" rel="noreferrer">Resume</a>
              </div>
            </div>

            <div class="hero-side">
				<aside class="snapshot-card glass">
					<h2>At a Glance</h2>
					<ul class="snapshot-list">
					<li>Computer Engineering student at Concordia University</li>
					<li>Building embedded, firmware, and software projects</li>
					<li>Focused on clean architecture, testing, and practical functionality</li>
					<li>Interested in real systems, product-style engineering, and continuous improvement</li>
					</ul>
				</aside>
			</div>
        </section>

        <section id="about" class="container">
          <div class="section-heading">
            <div>
              <h2 class="section-title">About</h2>
              <p class="section-subtitle">
                A focused introduction that tells recruiters what kind of builder you are.
              </p>
            </div>
          </div>

          <div class="about-card glass">
            <p>
              I’m a Computer Engineering student at Concordia University building hands-on projects
              in embedded systems, software development, and practical developer tools. I enjoy
              turning ideas into working systems, whether that means writing firmware for
              microcontrollers, building desktop applications, or designing full-stack tools with a
              clean structure. My goal is to grow into an engineer who can design, build, test, and
              improve real products end to end.
            </p>
          </div>
        </section>

        <section id="projects" class="container">
          <div class="section-heading">
            <div>
              <h2 class="section-title">Featured Projects</h2>
              <p class="section-subtitle">
                The strongest version of your portfolio is not more projects. It is better-presented
                projects.
              </p>
            </div>
          </div>

          <div class="projects-grid">
            {projects.map((project, index) => (
              <article class="project-card glass">
                <div class="project-top">
                  <span class="project-index">0{index + 1}</span>
                </div>

                <h3>{project.title}</h3>
                <p>{project.description}</p>

                <ul>
                  {project.bullets.map((bullet) => (
                    <li>{bullet}</li>
                  ))}
                </ul>

                <p class="tech"><strong>Tech:</strong> {project.tech}</p>

                <div class="project-links">
                  <a href={project.github} target="_blank" rel="noreferrer">View on GitHub →</a>
                </div>
              </article>
            ))}
          </div>
        </section>

        <section id="skills" class="container">
          <div class="section-heading">
            <div>
              <h2 class="section-title">Skills</h2>
              <p class="section-subtitle">
                Keep this grouped and readable. A clean layout looks stronger than a giant wall of badges.
              </p>
            </div>
          </div>

          <div class="skills-grid">
            {Object.entries(skills).map(([group, items]) => (
              <div class="section-card glass">
                <h3>{group}</h3>
                <div class="tag-list">
                  {items.map((item) => (
                    <span class="tag">{item}</span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </section>

        <section id="working-on" class="container">
          <div class="section-heading">
            <div>
              <h2 class="section-title">What I’m Working On</h2>
              <p class="section-subtitle">
                This makes the site feel active and shows that your work is evolving.
              </p>
            </div>
          </div>

          <div class="working-grid">
            <div class="section-card glass">
              <ul class="working-list">
                <li>Improving firmware architecture and reliability for my gesture-controlled music controller</li>
                <li>Expanding software projects with cleaner structure, better testing, and better deployment</li>
                <li>Building a portfolio that shows both embedded and software engineering depth</li>
              </ul>
            </div>

            <div class="callout">
              <p>
                I’m especially interested in opportunities where I can contribute to real systems,
                improve engineering fundamentals, and keep leveling up through practical work.
              </p>
            </div>
          </div>
        </section>

        <section id="contact" class="container">
          <div class="contact-card glass">
            <div class="contact-top">
              <div>
                <h2 class="section-title">Contact</h2>
                <p>
                  I’m currently looking for internship and early-career opportunities where I can
                  contribute, learn quickly, and keep building strong engineering fundamentals.
                </p>
              </div>
            </div>

            <div class="contact-links">
              <a class="btn primary" href="mailto:your.email@example.com">Email Me</a>
              <a class="btn" href="https://github.com/yourusername" target="_blank" rel="noreferrer">GitHub</a>
              <a class="btn" href="https://www.linkedin.com/in/yourusername" target="_blank" rel="noreferrer">LinkedIn</a>
              <a class="btn" href="/resume.pdf" target="_blank" rel="noreferrer">Resume</a>
            </div>
          </div>
        </section>
      </main>

      <footer class="container">
        <div class="footer-box">
          © 2026 Harish Thandayutham. Built with Astro.
        </div>
      </footer>
    </div>
  </body>
</html>